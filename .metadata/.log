		 */
		byte opcode = dis.readByte();
		PeerMessage message = new PeerMessage(opcode);
		switch (opcode) {
			case PeerMessageOps.OPCODE_PEER_FILES_REQ: {
				break;
			}
			case PeerMessageOps.OPCODE_PEER_FILES_REPLY: {
				int tam=dis.readInt();
